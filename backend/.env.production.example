# Copy ไฟล์นี้เป็น .env.production แล้วแก้ค่าให้ถูกต้อง

# เชื่อม postgres container ที่มีอยู่
# ถ้าอยู่ใน docker network เดียวกัน ใช้ชื่อ container ได้เลย
DATABASE_URL="postgresql://postgres:YOUR_PG_PASSWORD@postgres-ai:5432/bpv_dashboard"

JWT_SECRET="bpv-dashboard-super-secret-jwt-key-CHANGE_THIS"
JWT_REFRESH_SECRET="bpv-dashboard-refresh-secret-CHANGE_THIS"
PORT=3001

# Vercel URL + localhost dev (คั่นด้วย comma)
CORS_ORIGINS="https://bpv-dashboard.vercel.app,http://localhost:5173"

# S3 / MinIO (ถ้าไม่ใช้ image upload ให้ปล่อยว่างได้)
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="bpv-worksheets"
S3_REGION="us-east-1"
